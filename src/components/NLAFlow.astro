---
type Step = {
  label: string;
  title: string;
  body: string;
};

interface Props {
  title?: string;
  subtitle?: string;
  steps: Step[];
}

const {
  title = "Natural language autoencoder",
  subtitle = "A frozen model activation is translated into text, then reconstructed from that text.",
  steps,
} = Astro.props as Props;
---

<section class="not-prose my-8 rounded-3xl border border-stone-200/80 bg-white/80 p-5 shadow-sm shadow-stone-200/40 dark:border-stone-800 dark:bg-stone-950/70 dark:shadow-none">
  <div class="mb-5 space-y-1">
    <p class="text-xs font-medium uppercase tracking-[0.18em] text-stone-500 dark:text-stone-400">
      Flow
    </p>
    <h3 class="text-lg font-semibold text-black dark:text-white">{title}</h3>
    <p class="text-sm leading-6 text-stone-600 dark:text-stone-300">{subtitle}</p>
  </div>

  <div class="grid gap-3 md:grid-cols-2">
    {steps.map((step, index) => (
      <div class="relative rounded-2xl border border-stone-200 bg-stone-50/80 p-4 dark:border-stone-800 dark:bg-stone-900/80">
        <div class="mb-3 flex items-center gap-3">
          <div class="flex h-8 w-8 items-center justify-center rounded-full bg-black text-xs font-semibold text-white dark:bg-white dark:text-black">
            {index + 1}
          </div>
          <div>
            <p class="text-[11px] uppercase tracking-[0.16em] text-stone-500 dark:text-stone-400">
              {step.label}
            </p>
            <p class="text-sm font-semibold text-black dark:text-white">{step.title}</p>
          </div>
        </div>
        <p class="text-sm leading-6 text-stone-600 dark:text-stone-300">{step.body}</p>
      </div>
    ))}
  </div>
</section>
